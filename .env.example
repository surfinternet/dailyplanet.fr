# ============================================================
# Daily Planet FR — Pipeline de publication automatisée
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# Mode de fonctionnement
# local      = utilise Claude Code CLI (abonnement connecté)
# production = utilise OpenRouter API claude-sonnet-4-6 (payant)
MODE=local
# MODE=production

# ------------------------------------------------------------
# OpenRouter — requis pour recherche news (Perplexity)
# et rédaction en mode production
# Obtenir une clé sur https://openrouter.ai
# ------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-remplacez-par-votre-cle

# ------------------------------------------------------------
# kie.ai — requis pour génération image
# 16:9 natif, ~2K résolution, style illustration
# Obtenir une clé sur https://kie.ai/api-key
# ------------------------------------------------------------
KIE_AI_API_KEY=remplacez-par-votre-cle-kie

# Modèle image kie.ai
# Familles disponibles :
#   flux-kontext-pro / flux-kontext-max  → endpoint /flux/kontext/generate
#   gpt-image-2-text-to-image            → endpoint /jobs/createTask
#   nano-banana-pro                      → endpoint /jobs/createTask (4K possible)
#   flux-2/pro-text-to-image             → endpoint /jobs/createTask
KIE_AI_MODEL=gpt-image-2-text-to-image

# ------------------------------------------------------------
# Claude CLI — mode local uniquement
# Chemin vers l'exécutable (vérifier avec: which claude)
# ------------------------------------------------------------
CLAUDE_CLI_PATH=/Users/frankbonnet/.local/bin/claude

# ------------------------------------------------------------
# Claude API — mode production uniquement (OpenRouter)
# Modèle utilisé pour la rédaction
# ------------------------------------------------------------
CLAUDE_MODEL=anthropic/claude-sonnet-4-6

# ------------------------------------------------------------
# Chemins du projet Hugo
# ------------------------------------------------------------
HUGO_SITE_PATH=/Users/frankbonnet/Developer/projects/dailyplanet.fr

# ------------------------------------------------------------
# Site
# ------------------------------------------------------------
SITE_BASE_URL=https://dailyplanet.fr

# ------------------------------------------------------------
# Git — identité pour les commits automatiques (VPS)
# ------------------------------------------------------------
GIT_USER_NAME=Daily Planet Bot
GIT_USER_EMAIL=bot@dailyplanet.fr

# ------------------------------------------------------------
# Dashboard admin — http://VPS_IP:8080
# ------------------------------------------------------------
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changez-ce-mot-de-passe
DASHBOARD_PORT=8080
VPS_HOST=46.202.130.138

# ------------------------------------------------------------
# Alertes email — envoi automatique en cas d'échec du pipeline
# Utiliser Gmail avec un "App Password" (pas votre vrai mdp)
# Créer un App Password : myaccount.google.com/apppasswords
# ------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
ALERT_EMAIL=frank@surf-internet.com

# ------------------------------------------------------------
# Tarifs API pour le calcul des coûts (USD / 1M tokens)
# Valeurs par défaut correctes pour OpenRouter — modifier si
# vous avez des accords tarifaires différents.
# ------------------------------------------------------------
PRICE_PERPLEXITY_IN=3.0
PRICE_PERPLEXITY_OUT=15.0
PRICE_CLAUDE_IN=3.0
PRICE_CLAUDE_OUT=15.0
# Coût fixe par image générée (kie.ai gpt-image-2 : ~0.04$)
PRICE_IMAGE_USD=0.04
